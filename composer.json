{
  "name": "peace-seafood/app",
  "description": "Peace Seafood - Warehouse Management System",
  "type": "project",
  "require": {
    "php": ">=8.2",
    "firebase/php-jwt": "^6.11",
    "dompdf/dompdf": "^2.0",
    "phpoffice/phpspreadsheet": "^3.0",
    "vlucas/phpdotenv": "^5.5",
    "monolog/monolog": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    },
    "classmap": [
      "src/"
    ]
  },
  "config": {
    "optimize-autoloader": false,
    "audit": {
      "ignore": ["PKSA-y2cr-5h3j-g3ys"],
      "abandoned": "ignore"
    }
  }
}
