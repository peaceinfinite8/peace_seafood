{
  "module": "stok",
  "description": "Inventory/stock management tables",
  "tables": [
    {
      "name": "stok_masuk",
      "description": "Incoming stock transactions from suppliers",
      "fields": [
        {
          "name": "id",
          "type": "INT",
          "constraint": "PRIMARY KEY AUTO_INCREMENT"
        },
        { "name": "id_gudang", "type": "INT", "constraint": "NOT NULL" },
        { "name": "id_produk", "type": "INT", "constraint": "NOT NULL" },
        { "name": "id_supplier", "type": "INT", "constraint": "NOT NULL" },
        { "name": "qty", "type": "DECIMAL(10,2)", "constraint": "NOT NULL" },
        { "name": "harga_beli", "type": "BIGINT", "constraint": "NOT NULL" },
        {
          "name": "status",
          "type": "ENUM('pending', 'confirmed')",
          "constraint": "DEFAULT 'pending'"
        },
        { "name": "created_by", "type": "INT", "constraint": "NOT NULL" },
        {
          "name": "created_at",
          "type": "TIMESTAMP",
          "constraint": "DEFAULT CURRENT_TIMESTAMP"
        }
      ],
      "indexes": [
        { "name": "idx_id_gudang", "columns": ["id_gudang"] },
        { "name": "idx_id_produk", "columns": ["id_produk"] },
        { "name": "idx_status", "columns": ["status"] }
      ],
      "foreignKeys": [
        { "column": "id_gudang", "references": "gudang(id)" },
        { "column": "id_produk", "references": "produk(id)" },
        { "column": "id_supplier", "references": "supplier(id)" },
        { "column": "created_by", "references": "users(id)" }
      ]
    },
    {
      "name": "timbangan",
      "description": "Weighing/quality checking records after receiving stock",
      "fields": [
        {
          "name": "id",
          "type": "INT",
          "constraint": "PRIMARY KEY AUTO_INCREMENT"
        },
        { "name": "id_stok_masuk", "type": "INT", "constraint": "NOT NULL" },
        { "name": "id_produk", "type": "INT", "constraint": "NOT NULL" },
        {
          "name": "qty_teoritis",
          "type": "DECIMAL(10,2)",
          "constraint": "NOT NULL"
        },
        {
          "name": "qty_actual",
          "type": "DECIMAL(10,2)",
          "constraint": "NOT NULL"
        },
        {
          "name": "selisih",
          "type": "DECIMAL(10,2)",
          "constraint": "GENERATED ALWAYS AS (qty_teoritis - qty_actual) STORED"
        },
        {
          "name": "persen_susut",
          "type": "DECIMAL(5,2)",
          "constraint": "GENERATED ALWAYS AS ((qty_teoritis - qty_actual) / qty_teoritis * 100) STORED"
        },
        { "name": "alasan_susut", "type": "TEXT" },
        { "name": "created_by", "type": "INT", "constraint": "NOT NULL" },
        {
          "name": "created_at",
          "type": "TIMESTAMP",
          "constraint": "DEFAULT CURRENT_TIMESTAMP"
        }
      ],
      "indexes": [
        { "name": "idx_id_stok_masuk", "columns": ["id_stok_masuk"] },
        { "name": "idx_id_produk", "columns": ["id_produk"] }
      ],
      "foreignKeys": [
        { "column": "id_stok_masuk", "references": "stok_masuk(id)" },
        { "column": "id_produk", "references": "produk(id)" },
        { "column": "created_by", "references": "users(id)" }
      ]
    },
    {
      "name": "stok_opname",
      "description": "Regular physical inventory count/verification",
      "fields": [
        {
          "name": "id",
          "type": "INT",
          "constraint": "PRIMARY KEY AUTO_INCREMENT"
        },
        { "name": "id_gudang", "type": "INT", "constraint": "NOT NULL" },
        { "name": "tanggal_opname", "type": "DATE", "constraint": "NOT NULL" },
        {
          "name": "status",
          "type": "ENUM('draft', 'final')",
          "constraint": "DEFAULT 'draft'"
        },
        { "name": "created_by", "type": "INT", "constraint": "NOT NULL" },
        {
          "name": "created_at",
          "type": "TIMESTAMP",
          "constraint": "DEFAULT CURRENT_TIMESTAMP"
        }
      ],
      "indexes": [
        { "name": "idx_id_gudang", "columns": ["id_gudang"] },
        { "name": "idx_tanggal", "columns": ["tanggal_opname"] }
      ],
      "foreignKeys": [
        { "column": "id_gudang", "references": "gudang(id)" },
        { "column": "created_by", "references": "users(id)" }
      ]
    }
  ]
}
