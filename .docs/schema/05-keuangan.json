{
  "module": "keuangan",
  "description": "Financial/accounting tables for debts and credits",
  "tables": [
    {
      "name": "hutang_piutang",
      "description": "Flexible debt/credit tracking for both suppliers and buyers",
      "fields": [
        {
          "name": "id",
          "type": "INT",
          "constraint": "PRIMARY KEY AUTO_INCREMENT"
        },
        { "name": "id_gudang", "type": "INT", "constraint": "NOT NULL" },
        {
          "name": "jenis",
          "type": "ENUM('hutang', 'piutang')",
          "constraint": "NOT NULL"
        },
        { "name": "id_supplier", "type": "INT", "constraint": "NULLABLE" },
        { "name": "id_pembeli", "type": "INT", "constraint": "NULLABLE" },
        { "name": "id_nota", "type": "INT", "constraint": "NULLABLE" },
        { "name": "no_referensi", "type": "VARCHAR(50)" },
        { "name": "nominal", "type": "BIGINT", "constraint": "NOT NULL" },
        {
          "name": "nominal_bayar",
          "type": "BIGINT",
          "constraint": "DEFAULT 0"
        },
        {
          "name": "sisa_hutang",
          "type": "BIGINT",
          "constraint": "GENERATED ALWAYS AS (nominal - nominal_bayar) STORED"
        },
        { "name": "jatuh_tempo", "type": "DATE", "constraint": "NOT NULL" },
        {
          "name": "status",
          "type": "ENUM('open', 'sebagian', 'lunas')",
          "constraint": "DEFAULT 'open'"
        },
        { "name": "created_by", "type": "INT", "constraint": "NOT NULL" },
        {
          "name": "created_at",
          "type": "TIMESTAMP",
          "constraint": "DEFAULT CURRENT_TIMESTAMP"
        }
      ],
      "indexes": [
        { "name": "idx_id_gudang", "columns": ["id_gudang"] },
        { "name": "idx_jenis", "columns": ["jenis"] },
        { "name": "idx_id_supplier", "columns": ["id_supplier"] },
        { "name": "idx_id_pembeli", "columns": ["id_pembeli"] },
        { "name": "idx_status", "columns": ["status"] },
        { "name": "idx_jatuh_tempo", "columns": ["jatuh_tempo"] }
      ],
      "foreignKeys": [
        { "column": "id_gudang", "references": "gudang(id)" },
        { "column": "id_supplier", "references": "supplier(id)" },
        { "column": "id_pembeli", "references": "pembeli(id)" },
        { "column": "id_nota", "references": "nota(id)" },
        { "column": "created_by", "references": "users(id)" }
      ]
    },
    {
      "name": "hutang_piutang_history",
      "description": "Payment history for tracking payments",
      "fields": [
        {
          "name": "id",
          "type": "INT",
          "constraint": "PRIMARY KEY AUTO_INCREMENT"
        },
        {
          "name": "id_hutang_piutang",
          "type": "INT",
          "constraint": "NOT NULL"
        },
        { "name": "nominal_bayar", "type": "BIGINT", "constraint": "NOT NULL" },
        { "name": "metode_bayar", "type": "VARCHAR(50)" },
        { "name": "keterangan", "type": "TEXT" },
        { "name": "created_by", "type": "INT", "constraint": "NOT NULL" },
        {
          "name": "created_at",
          "type": "TIMESTAMP",
          "constraint": "DEFAULT CURRENT_TIMESTAMP"
        }
      ],
      "indexes": [
        { "name": "idx_id_hutang_piutang", "columns": ["id_hutang_piutang"] },
        { "name": "idx_tanggal", "columns": ["created_at"] }
      ],
      "foreignKeys": [
        { "column": "id_hutang_piutang", "references": "hutang_piutang(id)" },
        { "column": "created_by", "references": "users(id)" }
      ]
    },
    {
      "name": "biaya_operasional",
      "description": "Operational expenses",
      "fields": [
        {
          "name": "id",
          "type": "INT",
          "constraint": "PRIMARY KEY AUTO_INCREMENT"
        },
        { "name": "id_gudang", "type": "INT", "constraint": "NOT NULL" },
        { "name": "kategori", "type": "VARCHAR(50)", "constraint": "NOT NULL" },
        { "name": "deskripsi", "type": "TEXT" },
        { "name": "nominal", "type": "BIGINT", "constraint": "NOT NULL" },
        { "name": "tanggal", "type": "DATE", "constraint": "NOT NULL" },
        { "name": "created_by", "type": "INT", "constraint": "NOT NULL" },
        {
          "name": "created_at",
          "type": "TIMESTAMP",
          "constraint": "DEFAULT CURRENT_TIMESTAMP"
        }
      ],
      "indexes": [
        { "name": "idx_id_gudang", "columns": ["id_gudang"] },
        { "name": "idx_kategori", "columns": ["kategori"] },
        { "name": "idx_tanggal", "columns": ["tanggal"] }
      ],
      "foreignKeys": [
        { "column": "id_gudang", "references": "gudang(id)" },
        { "column": "created_by", "references": "users(id)" }
      ]
    }
  ]
}
