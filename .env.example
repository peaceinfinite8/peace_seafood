APP_NAME=Peace Seafood
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Jakarta

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=peace_seafood
DB_USER=root
DB_PASSWORD=

JWT_SECRET=change-this-to-a-random-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION=1800

UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,gif,pdf

EXPORT_MAX_ROWS=10000

LOG_CHANNEL=single
LOG_LEVEL=debug

# Session Configuration (30 minutes)
SESSION_TIMEOUT_MINUTES=30
SESSION_NAME=PEACE_SEAFOOD_SESSION
SESSION_COOKIE_LIFETIME=1800
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Strict

CORS_ORIGIN=http://localhost
