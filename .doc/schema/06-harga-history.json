{
  "module": "harga_history",
  "description": "Price history and tracking for cost of goods sold (COGS) calculation",
  "tables": [
    {
      "name": "harga_history",
      "description": "Track all price changes for historical cost calculation",
      "fields": [
        {
          "name": "id",
          "type": "INT",
          "constraint": "PRIMARY KEY AUTO_INCREMENT"
        },
        { "name": "id_produk", "type": "INT", "constraint": "NOT NULL" },
        { "name": "harga_lama", "type": "BIGINT" },
        { "name": "harga_baru", "type": "BIGINT", "constraint": "NOT NULL" },
        {
          "name": "tipe",
          "type": "ENUM('beli', 'jual')",
          "constraint": "NOT NULL"
        },
        { "name": "reason", "type": "VARCHAR(255)" },
        { "name": "changed_by", "type": "INT", "constraint": "NOT NULL" },
        {
          "name": "created_at",
          "type": "TIMESTAMP",
          "constraint": "DEFAULT CURRENT_TIMESTAMP"
        }
      ],
      "indexes": [
        { "name": "idx_id_produk", "columns": ["id_produk"] },
        { "name": "idx_tipe", "columns": ["tipe"] },
        { "name": "idx_created_at", "columns": ["created_at"] }
      ],
      "foreignKeys": [
        { "column": "id_produk", "references": "produk(id)" },
        { "column": "changed_by", "references": "users(id)" }
      ]
    },
    {
      "name": "retur",
      "description": "Return/adjustment tracking for both stock and financial adjustments",
      "fields": [
        {
          "name": "id",
          "type": "INT",
          "constraint": "PRIMARY KEY AUTO_INCREMENT"
        },
        { "name": "id_gudang", "type": "INT", "constraint": "NOT NULL" },
        { "name": "id_produk", "type": "INT", "constraint": "NULLABLE" },
        { "name": "id_supplier", "type": "INT", "constraint": "NULLABLE" },
        { "name": "id_pembeli", "type": "INT", "constraint": "NULLABLE" },
        {
          "name": "tipe",
          "type": "ENUM('stok', 'piutang')",
          "constraint": "NOT NULL"
        },
        { "name": "qty", "type": "DECIMAL(10,2)", "constraint": "NULLABLE" },
        { "name": "nominal", "type": "BIGINT", "constraint": "NULLABLE" },
        { "name": "alasan", "type": "VARCHAR(255)", "constraint": "NOT NULL" },
        { "name": "foto_bukti", "type": "VARCHAR(255)" },
        {
          "name": "status",
          "type": "ENUM('pending', 'approved', 'rejected', 'posted')",
          "constraint": "DEFAULT 'pending'"
        },
        { "name": "created_by", "type": "INT", "constraint": "NOT NULL" },
        { "name": "approved_by", "type": "INT", "constraint": "NULLABLE" },
        {
          "name": "approved_at",
          "type": "TIMESTAMP",
          "constraint": "NULLABLE"
        },
        {
          "name": "created_at",
          "type": "TIMESTAMP",
          "constraint": "DEFAULT CURRENT_TIMESTAMP"
        }
      ],
      "indexes": [
        { "name": "idx_id_gudang", "columns": ["id_gudang"] },
        { "name": "idx_tipe", "columns": ["tipe"] },
        { "name": "idx_status", "columns": ["status"] },
        { "name": "idx_id_produk", "columns": ["id_produk"] }
      ],
      "foreignKeys": [
        { "column": "id_gudang", "references": "gudang(id)" },
        { "column": "id_produk", "references": "produk(id)" },
        { "column": "id_supplier", "references": "supplier(id)" },
        { "column": "id_pembeli", "references": "pembeli(id)" },
        { "column": "created_by", "references": "users(id)" },
        { "column": "approved_by", "references": "users(id)" }
      ]
    },
    {
      "name": "notifikasi",
      "description": "In-app notifications for system alerts",
      "fields": [
        {
          "name": "id",
          "type": "INT",
          "constraint": "PRIMARY KEY AUTO_INCREMENT"
        },
        { "name": "id_user", "type": "INT", "constraint": "NOT NULL" },
        { "name": "tipe", "type": "VARCHAR(50)", "constraint": "NOT NULL" },
        { "name": "judul", "type": "VARCHAR(255)", "constraint": "NOT NULL" },
        { "name": "pesan", "type": "TEXT", "constraint": "NOT NULL" },
        { "name": "reference_id", "type": "INT" },
        { "name": "reference_tipe", "type": "VARCHAR(50)" },
        { "name": "is_read", "type": "TINYINT", "constraint": "DEFAULT 0" },
        { "name": "read_at", "type": "TIMESTAMP", "constraint": "NULLABLE" },
        {
          "name": "created_at",
          "type": "TIMESTAMP",
          "constraint": "DEFAULT CURRENT_TIMESTAMP"
        }
      ],
      "indexes": [
        { "name": "idx_id_user", "columns": ["id_user"] },
        { "name": "idx_tipe", "columns": ["tipe"] },
        { "name": "idx_is_read", "columns": ["is_read"] },
        { "name": "idx_created_at", "columns": ["created_at"] }
      ],
      "foreignKeys": [{ "column": "id_user", "references": "users(id)" }]
    },
    {
      "name": "settings",
      "description": "Application configuration settings per warehouse",
      "fields": [
        {
          "name": "id",
          "type": "INT",
          "constraint": "PRIMARY KEY AUTO_INCREMENT"
        },
        { "name": "id_gudang", "type": "INT", "constraint": "NULLABLE" },
        { "name": "kunci", "type": "VARCHAR(100)", "constraint": "NOT NULL" },
        { "name": "nilai", "type": "TEXT", "constraint": "NOT NULL" },
        { "name": "deskripsi", "type": "TEXT" },
        {
          "name": "updated_at",
          "type": "TIMESTAMP",
          "constraint": "DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP"
        }
      ],
      "indexes": [
        { "name": "idx_kunci", "columns": ["kunci"] },
        { "name": "idx_id_gudang", "columns": ["id_gudang"] }
      ],
      "foreignKeys": [{ "column": "id_gudang", "references": "gudang(id)" }]
    }
  ]
}
